public Int slowDouble(Int x) {
    Time::sleep(50);
    return x * 2;
}

main() {
    Fiber<Int> a = Fiber.spawn { slowDouble(10) };
    Fiber<Int> b = Fiber.spawn { slowDouble(20) };
    Fiber<Int> c = Fiber.spawn { slowDouble(30) };

    Int sum = a.await() + b.await() + c.await();
    println("Sum of doubles: $(sum)");
}
