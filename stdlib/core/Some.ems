namespace Std::Core;

public class Some<T> implements IOption<T> {
    private T value;

    public Some(T value) {
        this.value = value;
    }

    public Bool isSome() {
        return true;
    }

    public Bool isNone() {
        return false;
    }

    public T orElse(T fallback) {
        return this.value;
    }

    public T value() {
        return this.value;
    }
}
