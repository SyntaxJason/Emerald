namespace Std::Core;

public class Success<T, E> implements IResult<T, E> {
    private T value;

    public Success(T value) {
        this.value = value;
    }

    public Bool isOk() {
        return true;
    }

    public Bool isErr() {
        return false;
    }

    public T unwrapOr(T fallback) {
        return this.value;
    }

    public E errorOr(E fallback) {
        return fallback;
    }

    public T value() {
        return this.value;
    }
}
